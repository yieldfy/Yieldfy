{
  "name": "yieldfy",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm -w @yieldfy/dashboard run dev",
    "dev:all": "./ops/dev.sh",
    "build": "npm -w @yieldfy/sdk run build && npm -w @yieldfy/dashboard run build",
    "lint": "npm -w @yieldfy/dashboard run lint",
    "test": "npm -ws --if-present run test",
    "optimizer:dev": "npm -w @yieldfy/optimizer run dev",
    "sdk:build": "npm -w @yieldfy/sdk run build",
    "anchor:test": "cd tests && npm install --no-save && npm test"
  },
  "engines": {
    "node": ">=20"
  }
}
