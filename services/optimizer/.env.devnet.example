# Optimizer env for pointing at the live devnet Yieldfy program.
#
#   YIELDFY_ATTESTOR_KEY must be the ed25519 secret key that matches
#   Config.attestor on-chain. For devnet that secret lives in
#   ops/artifacts/devnet/attestor.json (git-ignored). Load it at process
#   start:
#
#     YIELDFY_ATTESTOR_KEY="$(cat ops/artifacts/devnet/attestor.json)" \
#       npm -w @yieldfy/optimizer run dev

SOLANA_RPC_URL=https://api.devnet.solana.com
PORT=4000

# Expected pubkey: 76XD6xfJhXoH7HhyywhTvkX5RT1etAoot3HN4AF1wHXb
# Verify with: curl http://localhost:4000/attestor/pubkey
YIELDFY_ATTESTOR_KEY=

# Optional — Redis-backed webhook store. Leave blank for the in-memory store.
# REDIS_URL=redis://localhost:6379

# Optional — rate limits for /attest.
ATTEST_RATE_MAX=60
ATTEST_RATE_WINDOW=1 minute

# Optional — Axiom observability.
# AXIOM_TOKEN=
# AXIOM_DATASET=yieldfy-optimizer
# AXIOM_ORG_ID=
