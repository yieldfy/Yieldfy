{
  "name": "@yieldfy/rewards-indexer",
  "version": "0.1.0",
  "private": true,
  "description": "Yieldfy SOL rewards indexer. Snapshots $YIELDFY holders + wXRP vault positions every epoch, computes per-wallet SOL distributions via @yieldfy/sdk scoring, publishes a merkle root with per-leaf claim proofs.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "epoch:run": "tsx src/cli.ts run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0",
    "@sqds/multisig": "^2.1.4",
    "@yieldfy/sdk": "*",
    "fastify": "^4.28.1",
    "keccak256": "^1.0.6",
    "merkletreejs": "^0.5.2",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
