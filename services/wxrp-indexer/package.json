{
  "name": "@yieldfy/wxrp-indexer",
  "private": true,
  "version": "0.1.0",
  "description": "Hex Trust wXRP mint/burn observer. Polls the wXRP mint supply on Solana and emits deltas as structured events + Prometheus counters.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0",
    "fastify": "^4.28.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
